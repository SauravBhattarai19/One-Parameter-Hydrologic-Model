# Plugin build artifacts
#   vsa_opm/            = the pip-installable core package (tracked source)
#   qgis_plugin/        = plugin SOURCE (tracked so it can be maintained/rebuilt)
#   _plugin_build/      = prebuilt self-contained vsa_opm_plugin/ (tracked so users
#                         can pull and drop it straight into their QGIS plugins dir)
#   vsa_opm_windows.zip = large zip artifact, kept out of git
vsa_opm_windows.zip
# never ship credentials inside the vendored package
_plugin_build/vsa_opm_plugin/_vendor/vsa_opm/gee/key.json

